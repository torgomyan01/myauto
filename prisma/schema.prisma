generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  id                   Int                     @id @default(autoincrement())
  email                String                  @unique(map: "User_email_key")
  name                 String
  password             String
  phone                String?
  role                 user_role               @default(USER)
  blocked              Boolean                 @default(false)
  legalEntityVerified  Boolean                 @default(false)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime
  garageCars           GarageCar[]
  legalEntityVerifications LegalEntityVerification[]
  notifications        Notification[]
}

model LegalEntityVerification {
  id              Int                        @id @default(autoincrement())
  user            user                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          Int
  companyName     String                     @db.VarChar(255)
  taxId           String                     @db.VarChar(64)
  legalAddress    String                     @db.VarChar(512)
  paymentProofPath String?                   @db.VarChar(512)
  paymentProofData String?                   @db.LongText
  amount          Int                       @default(1000)
  status          verification_status       @default(PENDING)
  rejectionReason String?                   @db.VarChar(512)
  submittedAt     DateTime                  @default(now())
  reviewedAt      DateTime?
  reviewedByUserId Int?
  @@index([userId])
  @@index([status])
  @@unique([userId])
}

enum verification_status {
  PENDING
  APPROVED
  REJECTED
}

enum user_role {
  USER
  ADMIN
}

model Notification {
  id        Int      @id @default(autoincrement())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  status    String   @db.VarChar(16)   // success | warning | error
  title     String   @db.VarChar(255)
  message   String   @db.VarChar(1024)
  href      String?  @db.VarChar(512)
  image     String?  @db.VarChar(512)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
}

model GarageCar {
  id         Int      @id @default(autoincrement())
  user       user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int
  vin        String   @db.VarChar(32)
  brand      String?  @db.VarChar(255)
  model      String?  @db.VarChar(255)
  year       String?  @db.VarChar(16)
  type       String?  @db.VarChar(64)
  markId     String?  @db.VarChar(191)
  modelId    String?  @db.VarChar(191)
  modificationId String? @db.VarChar(191)
  criteria   String?  @db.VarChar(191)
  criteria64 String?  @db.VarChar(191)
  image      String?  @db.VarChar(512)
  createdAt  DateTime @default(now())

  @@unique([userId, vin], map: "GarageCar_user_vin_key")
}

model SpareCategory {
  id        Int      @id @default(autoincrement())
  label     String   @unique @db.VarChar(191)
  href      String   @db.VarChar(512)
  image     String   @db.VarChar(512)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}
